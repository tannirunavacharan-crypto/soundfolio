PORT=5000
MONGODB_URI=mongodb://localhost:27017/soundfolio
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Email configuration (SMTP)
# If left empty, mailer will log inquiries to console for development
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
ADMIN_EMAIL=composer.akbhuker@example.com
SENDER_EMAIL=inquiries@soundfolio.com

# Firebase configurations (optional, falls back to MongoDB/JSON if not set)
# Option A: Individual Firebase service account credentials
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Option B: Or you can supply the entire service account JSON string as a single variable
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

